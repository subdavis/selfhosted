rssglue.{$DNS_DOMAIN} {
	# requires github.com/mholt/caddy-ratelimit built into the image (see Dockerfile)
	rate_limit {
		zone rssglue {
			key     {http.request.remote.host}
			events  100
			window  1s
		}
	}
	reverse_proxy rssglue:8000
}

