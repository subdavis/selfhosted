# Vaultwarden: Caddy proxies WebSocket transparently on port 80.
# If WEBSOCKET_ENABLED=true (legacy dual-port mode), route /notifications/hub
# to the dedicated WebSocket port and everything else to HTTP port.
vaultwarden.{$DNS_DOMAIN} {
	reverse_proxy /notifications/hub vaultwarden:3012
	reverse_proxy vaultwarden:80
}

# Unifi controller uses a self-signed HTTPS backend
unifi.{$DNS_DOMAIN} {
	import private_only
	reverse_proxy https://unifi_controller:8443 {
		transport http {
			tls_insecure_skip_verify
		}
	}
}
