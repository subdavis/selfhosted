# Copy to .env and fill in secrets. Used by workflow_explorer_postgres (POSTGRES_*)
# and mounted into the app container at /app/.env.

# --- LLM (Pydantic AI) ---
LLM_MODEL=anthropic:claude-sonnet-5
ANTHROPIC_API_KEY=CHANGEME
# OPENAI_API_KEY=CHANGEME
# OPENROUTER_API_KEY=CHANGEME

# --- Observability (Pydantic Logfire) ---
LOGFIRE_TOKEN=

# --- Webhooks ---
# Paperless (and other jobs) send: Authorization: Bearer <token>
WEBHOOK_BEARER_TOKEN=CHANGEME

# --- Paperless-ngx job ---
# Internal Docker hostname; Paperless is on paperless-net.
PAPERLESS_URL=http://paperless:8000/api
# Paperless-ngx API token (My Profile > generate token).
PAPERLESS_TOKEN=CHANGEME
PAPERLESS_SCAN_CRON=*/30 * * * *
PAPERLESS_SCAN_LIMIT=25
